-- Função para encontrar ferramentas
local function FindTool(weaponType)
    local char = Player.Character
    if not char then return nil end
    local backpack = Player.Backpack
    
    if weaponType == "Melee" then
        -- Procura por armas corpo a corpo
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("combat") or lowName:find("melee") or lowName:find("soco") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("combat") or lowName:find("melee") or lowName:find("soco") then
                    return item
                end
            end
        end
        
    elseif weaponType == "Sword" then
        -- Procura por espadas
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("sword") or lowName:find("katana") or lowName:find("blade") or lowName:find("cutlass") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("sword") or lowName:find("katana") or lowName:find("blade") or lowName:find("cutlass") then
                    return item
                end
            end
        end
        
    elseif weaponType == "Fruit" then
        -- Procura por frutas
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("fruit") or lowName:find("gomu") or lowName:find("mera") or lowName:find("power") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("fruit") or lowName:find("gomu") or lowName:find("mera") or lowName:find("power") then
                    return item
                end
            end
        end
        
    elseif weaponType == "Gun" then
        -- Procura por armas de fogo
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("gun") or lowName:find("pistol") or lowName:find("rifle") or lowName:find("cannon") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("gun") or lowName:find("pistol") or lowName:find("rifle") or lowName:find("cannon") then
                    return item
                end
            end
        end
    end
    
    return nil
end

-- Função para equipar arma
local function EquipWeapon(weaponType)
    local char = Player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    local tool = FindTool(weaponType)
    if not tool then return false end
    
    if tool.Parent ~= char then
        humanoid:EquipTool(tool)
        task.wait(0.1)
    end
    
    return true
end

-- Função para usar skill
local function UseSkill(key)
    pcall(function()
        -- Tenta encontrar remotes específicos do Sailor Piece
        local remotes = {
            ReplicatedStorage:FindFirstChild("Remotes"),
            ReplicatedStorage:FindFirstChild("Events"),
            ReplicatedStorage:FindFirstChild("Skills"),
            ReplicatedStorage:FindFirstChild("Combat"),
        }
        
        local keyToIndex = {
            [Enum.KeyCode.Z] = 1,
            [Enum.KeyCode.X] = 2,
            [Enum.KeyCode.C] = 3,
            [Enum.KeyCode.V] = 4,
        }
        
        local skillIndex = keyToIndex[key]
        
        -- Tenta enviar via remote
        for _, remote in ipairs(remotes) do
            if remote then
                local skillRemote = remote:FindFirstChild("UseSkill") or 
                                   remote:FindFirstChild("ActivateSkill") or
                                   remote:FindFirstChild("Skill")
                if skillRemote and skillRemote:IsA("RemoteEvent") then
                    skillRemote:FireServer(skillIndex)
                    return
                end
            end
        end
        
        -- Fallback: VirtualInputManager
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.03)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
    end)
end

-- Função para encontrar inimigos próximos
local function FindNearestEnemy(range)
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local pos = char.HumanoidRootPart.Position
    local nearest = nil
    local nearestDist = range or 30
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Player then
            local pchar = player.Character
            if pchar and pchar:FindFirstChild("HumanoidRootPart") and pchar:FindFirstChildOfClass("Humanoid") then
                local humanoid = pchar:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local dist = (pos - pchar.HumanoidRootPart.Position).Magnitude
                    if dist < nearestDist then
                        nearest = pchar
                        nearestDist = dist
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Loop de AutoSkill
local function RunAutoSkillLoop(stateKey, skillKey)
    return task.spawn(function()
        while SailorState[stateKey] do
            task.wait(SailorState.SkillDelay)
            
            pcall(function()
                if SailorState.UseMelee then
                    EquipWeapon("Melee")
                    UseSkill(skillKey)
                end
                
                if SailorState.UseSword then
                    EquipWeapon("Sword")
                    UseSkill(skillKey)
                end
                
                if SailorState.UseFruit then
                    EquipWeapon("Fruit")
                    UseSkill(skillKey)
                end
                
                if SailorState.UseGun then
                    EquipWeapon("Gun")
                    UseSkill(skillKey)
                end
            end)
        end
    end)
end

