-- Aba Boss
local function BuildBossTab()
    ClearContent()
    
    CreateSection("👑 BOSS SYSTEM")
    
    -- Boss Summon NPC Info
    local NPCLabel = Instance.new("Frame")
    NPCLabel.Parent = ContentContainer
    NPCLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    NPCLabel.BorderSizePixel = 0
    NPCLabel.Size = UDim2.new(1, 0, 0, 50)
    
    local NPCCorner = Instance.new("UICorner")
    NPCCorner.CornerRadius = UDim.new(0, 6)
    NPCCorner.Parent = NPCLabel
    
    local NPCStatus = Workspace:FindFirstChild("ServiceNPCs") and 
                      Workspace.ServiceNPCs:FindFirstChild("SummonBossNPC") and "✅ NPC ENCONTRADO" or "❌ NPC NÃO ENCONTRADO"
    
    local NPCStatusLabel = Instance.new("TextLabel")
    NPCStatusLabel.Parent = NPCLabel
    NPCStatusLabel.BackgroundTransparency = 1
    NPCStatusLabel.Size = UDim2.new(1, -20, 1, 0)
    NPCStatusLabel.Position = UDim2.new(0, 10, 0, 0)
    NPCStatusLabel.Font = Enum.Font.Gotham
    NPCStatusLabel.Text = "Summon NPC: " .. NPCStatus
    NPCStatusLabel.TextColor3 = (NPCStatus == "✅ NPC ENCONTRADO") and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    NPCStatusLabel.TextSize = 13
    NPCStatusLabel.TextWrapped = true
    NPCStatusLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Botão Teleport para NPC
    local TeleportButton = Instance.new("TextButton")
    TeleportButton.Parent = ContentContainer
    TeleportButton.BackgroundColor3 = Color3.fromRGB(255, 69, 0)
    TeleportButton.BorderSizePixel = 0
    TeleportButton.Size = UDim2.new(1, 0, 0, 40)
    TeleportButton.Font = Enum.Font.GothamBold
    TeleportButton.Text = "🚀 TELEPORT TO SUMMON NPC"
    TeleportButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    TeleportButton.TextSize = 14
    
    local TeleportCorner = Instance.new("UICorner")
    TeleportCorner.CornerRadius = UDim.new(0, 6)
    TeleportCorner.Parent = TeleportButton
    
    TeleportButton.MouseButton1Click:Connect(function()
        local summonNPC = Workspace:FindFirstChild("ServiceNPCs") and 
                         Workspace.ServiceNPCs:FindFirstChild("SummonBossNPC")
        if summonNPC and summonNPC:FindFirstChild("HumanoidRootPart") then
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = summonNPC.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
            end
        end
    end)
    
    CreateSection("🔥 BOSSES DISPONÍVEIS")
    
    -- Lista de bosses
    local bosses = {"Enel", "Mihawk", "Kaido", "Big Mom", "Shanks", "Blackbeard", "Akainu", "Kizaru", "Aokiji", "Doflamingo"}
    
    for _, bossName in ipairs(bosses) do
        CreateBossButton(ContentContainer, bossName)
    end
    
    CreateSection("⚔️ AUTO KILL BOSS")
    
    CreateToggle(ContentContainer, "Auto Kill Boss", function(enabled)
        SailorState.AutoKillBoss = enabled
        
        if enabled then
            task.spawn(function()
                while SailorState.AutoKillBoss do
                    task.wait(1)
                    local bosses = FindActiveBosses()
                    for _, boss in ipairs(bosses) do
                        KillBoss(boss)
                        task.wait(2)
                    end
                end
            end)
        end
    end)
end

