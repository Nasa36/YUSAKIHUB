-- Função para usar skill via RequestAbility
local function UseSkill(skillIndex)
    -- skillIndex: 1 = Z, 2 = X, 3 = C, 4 = V (provavelmente)
    pcall(function()
        -- Usando exatamente o remote que você forneceu
        local args = {
            [1] = skillIndex
        }
        
        ReplicatedStorage:WaitForChild("RemoteEvents", 9e9):WaitForChild("RequestAbility", 9e9):FireServer(unpack(args))
    end)
end

