-- Aba Skills (com RequestAbility)
local function BuildSkillsTab()
    ClearContent()
    
    CreateSection("⚡ AUTO SKILLS (RequestAbility)")
    
    CreateToggle(ContentContainer, "Auto Skill Z (Index 1)", function(enabled)
        SailorState.AutoSkillZ = enabled
        if enabled then RunAutoSkillLoop("AutoSkillZ", 1) end
    end)
    
    CreateToggle(ContentContainer, "Auto Skill X (Index 2)", function(enabled)
        SailorState.AutoSkillX = enabled
        if enabled then RunAutoSkillLoop("AutoSkillX", 2) end
    end)
    
    CreateToggle(ContentContainer, "Auto Skill C (Index 3)", function(enabled)
        SailorState.AutoSkillC = enabled
        if enabled then RunAutoSkillLoop("AutoSkillC", 3) end
    end)
    
    CreateToggle(ContentContainer, "Auto Skill V (Index 4)", function(enabled)
        SailorState.AutoSkillV = enabled
        if enabled then RunAutoSkillLoop("AutoSkillV", 4) end
    end)
    
    CreateSlider(ContentContainer, "Skill Delay", 0.05, 1, 0.1, function(value)
        SailorState.SkillDelay = value
    end)
end

