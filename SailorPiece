-- Conectar botões de aba
for i, tabButton in ipairs(Tabs) do
    tabButton.MouseButton1Click:Connect(function()
        for j, btn in ipairs(Tabs) do
            btn.BackgroundColor3 = j == i and Color3.fromRGB(255, 69, 0) or Color3.fromRGB(40, 40, 50)
        end
        
        if i == 1 then BuildSkillsTab()
        elseif i == 2 then BuildHakiTab()
        elseif i == 3 then BuildBossTab()
        elseif i == 4 then BuildWeaponsTab()
        end
    end)
end

