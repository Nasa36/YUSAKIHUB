-- Função para spawnar boss
local function SpawnBoss(bossName)
    pcall(function()
        local summonNPC = Workspace:FindFirstChild("ServiceNPCs") and 
                         Workspace.ServiceNPCs:FindFirstChild("SummonBossNPC")
        
        if summonNPC and summonNPC:FindFirstChild("HumanoidRootPart") then
            local prompt = summonNPC.HumanoidRootPart:FindFirstChild("SummonPrompt")
            
            if prompt and prompt:IsA("ProximityPrompt") then
                local char = Player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = summonNPC.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                    task.wait(0.5)
                    prompt:InputHoldBegin()
                    task.wait(1)
                    prompt:InputHoldEnd()
                    
                    -- Se tiver remote de seleção de boss
                    local selectRemote = ReplicatedStorage:FindFirstChild("RemoteEvents") and 
                                        ReplicatedStorage.RemoteEvents:FindFirstChild("SelectBossRemote")
                    if selectRemote and bossName then
                        selectRemote:FireServer(bossName)
                    end
                end
            end
        end
    end)
end

-- Função para encontrar bosses vivos
local function FindActiveBosses()
    local bosses = {}
    pcall(function()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
                local humanoid = obj:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local name = obj.Name:lower()
                    if name:find("boss") or name:find("king") or name:find("raid") or name:find("enel") or 
                       name:find("mihawk") or name:find("kaido") or name:find("big mom") or name:find("shanks") then
                        table.insert(bosses, obj)
                    end
                end
            end
        end
    end)
    return bosses
end

-- Função para matar boss
local function KillBoss(boss)
    if not boss then return end
    
    pcall(function()
        local char = Player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        
        local bossHRP = boss:FindFirstChild("HumanoidRootPart")
        local bossHumanoid = boss:FindFirstChildOfClass("Humanoid")
        
        if bossHRP and bossHumanoid and bossHumanoid.Health > 0 then
            char.HumanoidRootPart.CFrame = bossHRP.CFrame * CFrame.new(0, 0, 8)
            
            if SailorState.AutoSkillZ then
                UseSkill(1) -- RequestAbility com index 1 (Z)
            end
            if SailorState.AutoSkillX then
                task.wait(0.1)
                UseSkill(2) -- RequestAbility com index 2 (X)
            end
            if SailorState.AutoSkillC then
                task.wait(0.1)
                UseSkill(3) -- RequestAbility com index 3 (C)
            end
            if SailorState.AutoSkillV then
                task.wait(0.1)
                UseSkill(4) -- RequestAbility com index 4 (V)
            end
        end
    end)
end

-- Função para encontrar ferramentas
local function FindTool(weaponType)
    local char = Player.Character
    if not char then return nil end
    local backpack = Player.Backpack
    
    if weaponType == "Melee" then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("combat") or lowName:find("melee") or lowName:find("soco") or lowName:find("fist") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("combat") or lowName:find("melee") or lowName:find("soco") or lowName:find("fist") then
                    return item
                end
            end
        end
        
    elseif weaponType == "Sword" then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("sword") or lowName:find("katana") or lowName:find("blade") or lowName:find("cutlass") or lowName:find("saber") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("sword") or lowName:find("katana") or lowName:find("blade") or lowName:find("cutlass") or lowName:find("saber") then
                    return item
                end
            end
        end
        
    elseif weaponType == "Fruit" then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("fruit") or lowName:find("gomu") or lowName:find("mera") or lowName:find("power") or lowName:find("devil") then
                    return item
                end
            end
        end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local lowName = item.Name:lower()
                if lowName:find("fruit") or lowName:find("gomu") or lowName:find("mera") or lowName:find("power") or lowName:find("devil") then
                    return item
                end
            end
        end
    end
    
    return nil
end

-- Função para equipar arma
local function EquipWeapon(weaponType)
    local char = Player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    local tool = FindTool(weaponType)
    if not tool then return false end
    
    if tool.Parent ~= char then
        humanoid:EquipTool(tool)
    end
    
    return true
end

-- Loop de AutoSkill usando RequestAbility
local function RunAutoSkillLoop(stateKey, skillIndex)
    return task.spawn(function()
        while SailorState[stateKey] do
            task.wait(SailorState.SkillDelay)
            
            pcall(function()
                if SailorState.UseMelee then
                    if EquipWeapon("Melee") then
                        UseSkill(skillIndex)
                    end
                end
                
                if SailorState.UseSword then
                    task.wait(0.05)
                    if EquipWeapon("Sword") then
                        UseSkill(skillIndex)
                    end
                end
                
                if SailorState.UseFruit then
                    task.wait(0.05)
                    if EquipWeapon("Fruit") then
                        UseSkill(skillIndex)
                    end
                end
            end)
        end
    end)
end

