-- Função para verificar status do Haki (adaptar conforme o jogo)
local function CheckHakiStatus()
    pcall(function()
        local char = Player.Character
        if not char then return end
        
        -- Tenta detectar se Haki está ativo por efeitos visuais ou atributos
        -- Isso pode variar por jogo, então é uma estimativa
        local busoshokuActive = false
        local kenbunshokuActive = false
        
        -- Verifica por efeitos de Haki (exemplo: partes do corpo brilhando)
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("Part") or part:IsA("MeshPart") then
                -- Busoshoku geralmente deixa partes escuras/roxas
                if part.BrickColor == BrickColor.new("Really black") or 
                   part.BrickColor == BrickColor.new("Royal purple") then
                    busoshokuActive = true
                end
            end
        end
        
        -- Verifica por atributos ou valores (se existirem)
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            -- Alguns jogos usam atributos para Haki
            local busoAttr = humanoid:GetAttribute("Busoshoku")
            local kenAttr = humanoid:GetAttribute("Kenbunshoku")
            
            if busoAttr ~= nil then
                busoshokuActive = busoAttr
            end
            
            if kenAttr ~= nil then
                kenbunshokuActive = kenAttr
            end
        end
        
        HakiStatus.BusoshokuActive = busoshokuActive
        HakiStatus.KenbunshokuActive = kenbunshokuActive
    end)
end

-- Função para encontrar ferramentas (otimizada)
local function FindTool(weaponType)
    local char = Player.Character
    if not char then return nil end
    local backpack = Player.Backpack
    
    local searchTerms = {
        Melee = {"combat", "melee", "soco", "fist", "punch", "kick"},
        Sword = {"sword", "katana", "blade", "cutlass", "saber", "espada", "lâmina"},
        Fruit = {"fruit", "gomu", "mera", "power", "devil", "akuma", "fruta"}
    }
    
    local terms = searchTerms[weaponType]
    if not terms then return nil end
    
    -- Procura no inventário
    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            local lowName = item.Name:lower()
            for _, term in ipairs(terms) do
                if lowName:find(term) then
                    return item
                end
            end
        end
    end
    
    -- Procura no personagem
    for _, item in ipairs(char:GetChildren()) do
        if item:IsA("Tool") then
            local lowName = item.Name:lower()
            for _, term in ipairs(terms) do
                if lowName:find(term) then
                    return item
                end
            end
        end
    end
    
    return nil
end

-- Função para equipar arma
local function EquipWeapon(weaponType)
    local char = Player.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    local tool = FindTool(weaponType)
    if not tool then return false end
    
    if tool.Parent ~= char then
        humanoid:EquipTool(tool)
        task.wait(0.1) -- Pequeno delay para equipar
    end
    
    return true
end

-- Loop de AutoSkill CORRIGIDO
local function RunAutoSkillLoop(stateKey, skillIndex, skillName)
    return task.spawn(function()
        while SailorState[stateKey] do
            task.wait(SailorState.SkillDelay)
            
            local success = false
            
            -- Tenta cada arma ativa
            if SailorState.UseMelee and not success then
                if EquipWeapon("Melee") then
                    success = UseSkill(skillIndex)
                end
            end
            
            if SailorState.UseSword and not success then
                task.wait(0.05)
                if EquipWeapon("Sword") then
                    success = UseSkill(skillIndex)
                end
            end
            
            if SailorState.UseFruit and not success then
                task.wait(0.05)
                if EquipWeapon("Fruit") then
                    success = UseSkill(skillIndex)
                end
            end
            
            -- Se nenhuma arma funcionou, tenta usar skill sem equipar
            if not success then
                UseSkill(skillIndex)
            end
        end
    end)
end

