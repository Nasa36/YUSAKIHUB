-- YUSAKI HUB STYLE UI

local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local remotes = rs:WaitForChild("RemoteEvents")

_G.AutoSkill = false
_G.AutoHaki = false
_G.AutoObs = false
_G.ESP = false

-- REMOTES

local function Haki()
    remotes:WaitForChild("HakiRemote"):FireServer("Toggle")
end

local function Obs()
    remotes:WaitForChild("ObservationHakiRemote"):FireServer("Toggle")
end

local function Skill(id)
    remotes:WaitForChild("RequestAbility"):FireServer(id)
end

