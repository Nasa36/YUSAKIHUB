-- Função para usar skill via RequestAbility (CORRIGIDA)
local function UseSkill(skillIndex)
    -- skillIndex: 1 = Z, 2 = X, 3 = C, 4 = V
    local success = pcall(function()
        -- Garantir que os objetos existem
        local remoteEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
        if not remoteEvents then
            return false
        end
        
        local requestAbility = remoteEvents:FindFirstChild("RequestAbility")
        if not requestAbility then
            return false
        end
        
        -- Criar args no formato correto
        local args = { [1] = skillIndex }
        requestAbility:FireServer(unpack(args))
        return true
    end)
    
    return success
end

-- Função para ativar Busoshoku Haki
local function ActivateBusoshoku()
    pcall(function()
        local remoteEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
        if not remoteEvents then return end
        
        local hakiRemote = remoteEvents:FindFirstChild("HakiRemote")
        if not hakiRemote then return end
        
        local args = { [1] = "Toggle" }
        hakiRemote:FireServer(unpack(args))
    end)
end

