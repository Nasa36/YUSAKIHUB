-- ABA 1: Combat
local function BuildCombatTab()
    ClearContent()
    
    CreateSection("⚔ Combat Settings")
    
    CreateToggle(ContentContainer, "Auto Farm", "Automatically farm enemies", function(enabled)
        SailorState.AutoFarm = enabled
        
        if enabled then
            task.spawn(function()
                while SailorState.AutoFarm do
                    task.wait(0.1)
                    pcall(function()
                        local target = FindNearestEnemy(30)
                        if target and target:FindFirstChild("HumanoidRootPart") then
                            local char = Player.Character
                            if char and char:FindFirstChild("HumanoidRootPart") then
                                char.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                                
                                if SailorState.AutoAttack then
                                    UseSkill(Enum.KeyCode.Z)
                                end
                            end
                        end
                    end)
                end
            end)
        end
    end)
    
    CreateToggle(ContentContainer, "Auto Quest", "Automatically accept and complete quests", function(enabled)
        SailorState.AutoQuest = enabled
    end)
    
    CreateToggle(ContentContainer, "Auto Attack", "Automatically attack when farming", function(enabled)
        SailorState.AutoAttack = enabled
    end)
    
    CreateSlider(ContentContainer, "Skill Delay", "Delay between skill usage", 0.05, 2, 0.1, function(value)
        SailorState.SkillDelay = value
    end)
end

