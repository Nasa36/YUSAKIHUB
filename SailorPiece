-- CARD

local function Card(name,posY)

    local card = Instance.new("Frame",page)
    card.Size = UDim2.new(1,0,0,60)
    card.Position = UDim2.new(0,0,0,posY)
    card.BackgroundColor3 = Color3.fromRGB(35,35,60)
    Instance.new("UICorner",card).CornerRadius = UDim.new(0,8)

    local text = Instance.new("TextLabel",card)
    text.Text = name
    text.Size = UDim2.new(0.6,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.new(1,1,1)
    text.Font = Enum.Font.Gotham
    text.TextSize = 16

    local toggle = Instance.new("TextButton",card)
    toggle.Size = UDim2.new(0,50,0,25)
    toggle.Position = UDim2.new(1,-70,0.5,-12)
    toggle.BackgroundColor3 = Color3.fromRGB(120,90,255)
    toggle.Text = ""
    Instance.new("UICorner",toggle).CornerRadius = UDim.new(1,0)

    return toggle

end

-- TOGGLES

local skillToggle = Card("Auto Skills Z X C V",0)
local hakiToggle = Card("Auto Haki",70)
local obsToggle = Card("Observation Haki",140)
local espToggle = Card("ESP Players",210)

skillToggle.MouseButton1Click:Connect(function()
_G.AutoSkill = not _G.AutoSkill
end)

hakiToggle.MouseButton1Click:Connect(function()
_G.AutoHaki = not _G.AutoHaki
end)

obsToggle.MouseButton1Click:Connect(function()
_G.AutoObs = not _G.AutoObs
end)

espToggle.MouseButton1Click:Connect(function()
_G.ESP = not _G.ESP
end)

-- ESP

local function createESP(plr)

if plr == player then return end

plr.CharacterAdded:Connect(function(char)

repeat task.wait() until char:FindFirstChild("Head") and char:FindFirstChild("Humanoid")

local head = char.Head
local hum = char.Humanoid

local bill = Instance.new("BillboardGui",head)
bill.Size = UDim2.new(0,200,0,50)
bill.AlwaysOnTop = true

local txt = Instance.new("TextLabel",bill)
txt.Size = UDim2.new(1,0,1,0)
txt.BackgroundTransparency = 1
txt.TextColor3 = Color3.fromRGB(255,0,0)
txt.TextScaled = true
txt.Font = Enum.Font.GothamBold

task.spawn(function()
while hum.Parent do
if _G.ESP then
txt.Text = plr.Name.." | HP: "..math.floor(hum.Health)
else
txt.Text = ""
end
task.wait(0.2)
end
end)

local hl = Instance.new("Highlight")
hl.FillColor = Color3.fromRGB(255,0,0)
hl.OutlineColor = Color3.new(1,1,1)
hl.Parent = char

end)

end

for _,v in pairs(game.Players:GetPlayers()) do
createESP(v)
end

game.Players.PlayerAdded:Connect(createESP)

-- LOOPS

task.spawn(function()
while task.wait(0.4) do
if _G.AutoSkill then
Skill(1)
Skill(2)
Skill(3)
Skill(4)
end
end
end)

task.spawn(function()
while task.wait(3) do
