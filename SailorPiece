-- ABA 5: Speed
local function BuildSpeedTab()
    ClearContent()
    
    CreateSection("⚡ Movement Settings")
    
    CreateToggle(ContentContainer, "Speed Boost", "Increase movement speed", function(enabled)
        SailorState.SpeedBoost = enabled
        
        if enabled then
            Connections.Speed = RunService.Heartbeat:Connect(function()
                if SailorState.SpeedBoost then
                    local char = Player.Character
                    if char and char:FindFirstChild("Humanoid") then
                        char.Humanoid.WalkSpeed = SailorState.SpeedValue
                    end
                end
            end)
        else
            if Connections.Speed then
                Connections.Speed:Disconnect()
                Connections.Speed = nil
                local char = Player.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = 16
                end
            end
        end
    end)
    
    CreateSlider(ContentContainer, "Speed Value", "Movement speed value", 16, 250, 50, function(value)
        SailorState.SpeedValue = value
    end)
    
    CreateToggle(ContentContainer, "Jump Boost", "Increase jump power", function(enabled)
        SailorState.JumpBoost = enabled
        
        if enabled then
            Connections.Jump = RunService.Heartbeat:Connect(function()
                if SailorState.JumpBoost then
                    local char = Player.Character
                    if char and char:FindFirstChild("Humanoid") then
                        char.Humanoid.JumpPower = SailorState.JumpValue
                    end
                end
            end)
        else
            if Connections.Jump then
                Connections.Jump:Disconnect()
                Connections.Jump = nil
                local char = Player.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.JumpPower = 50
                end
            end
        end
    end)
    
    CreateSlider(ContentContainer, "Jump Value", "Jump power value", 50, 300, 100, function(value)
        SailorState.JumpValue = value
    end)
    
    CreateToggle(ContentContainer, "No Clip", "Walk through walls", function(enabled)
        SailorState.NoClip = enabled
        
        if enabled then
            Connections.NoClip = RunService.Stepped:Connect(function()
                if SailorState.NoClip then
                    local char = Player.Character
                    if char then
                        for _, part in ipairs(char:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end
                end
            end)
        else
            if Connections.NoClip then
                Connections.NoClip:Disconnect()
                Connections.NoClip = nil
                local char = Player.Character
                if char then
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = true
                        end
                    end
                end
            end
        end
    end)
    
    CreateToggle(ContentContainer, "Lock Position", "Lock your current position", function(enabled)
        SailorState.LockPosition = enabled
        
        if enabled then
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                SailorState.LockedPosition = char.HumanoidRootPart.CFrame
                
                Connections.LockPos = RunService.Heartbeat:Connect(function()
                    if SailorState.LockPosition and SailorState.LockedPosition then
                        local character = Player.Character
                        if character and character:FindFirstChild("HumanoidRootPart") then
                            character.HumanoidRootPart.CFrame = SailorState.LockedPosition
                            character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                        end
                    end
                end)
            end
        else
            if Connections.LockPos then
                Connections.LockPos:Disconnect()
                Connections.LockPos = nil
            end
            SailorState.LockedPosition = nil
        end
    end)
end

-- ABA 6: Misc
local function BuildMiscTab()
    ClearContent()
    
    CreateSection("⚙ Miscellaneous")
    
    CreateToggle(ContentContainer, "Auto Collect", "Automatically collect items", function(enabled)
        SailorState.AutoCollect = enabled
        
        if enabled then
            task.spawn(function()
                while SailorState.AutoCollect do
                    task.wait(0.5)
                    pcall(function()
                        local char = Player.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            for _, obj in ipairs(workspace:GetDescendants()) do
                                if obj:IsA("Part") and obj.Name:find("Chest") or obj.Name:find("Drop") then
                                    if (char.HumanoidRootPart.Position - obj.Position).Magnitude < 20 then
                                        char.HumanoidRootPart.CFrame = obj.CFrame * CFrame.new(0, 0, 3)
                                        firetouchinterest(char.HumanoidRootPart, obj, 0)
                                        task.wait(0.1)
                                        firetouchinterest(char.HumanoidRootPart, obj, 1)
                                    end
                                end
                            end
                        end
                    end)
                end
            end)
        end
    end)
    
    CreateToggle(ContentContainer, "Auto Click", "Automatically click", function(enabled)
        SailorState.AutoClick = enabled
        
        if enabled then
            task.spawn(function()
                while SailorState.AutoClick do
                    task.wait(0.01)
                    pcall(function()
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                        task.wait(0.01)
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                    end)
                end
            end)
        end
    end)
    
    CreateToggle(ContentContainer, "Anti AFK", "Prevent being kicked for AFK", function(enabled)
        SailorState.AntiAFK = enabled
        
        if enabled then
            Connections.AntiAFK = RunService.Heartbeat:Connect(function()
                if SailorState.AntiAFK then
                    pcall(function()
                        local char = Player.Character
                        if char and char:FindFirstChild("Humanoid") then
                            char.Humanoid:ChangeState("Jumping")
                            task.wait(0.1)
                            char.Humanoid:ChangeState("Running")
                        end
                    end)
                end
            end)
        else
            if Connections.AntiAFK then
                Connections.AntiAFK:Disconnect()
                Connections.AntiAFK = nil
            end
        end
    end)
end

