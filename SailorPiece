-- Aba Speed (Nova)
local function BuildSpeedTab()
    ClearContent()
    
    CreateSection("⚡ SPEED SYSTEM")
    
    CreateToggle(ContentContainer, "Speed Boost", function(enabled)
        SailorState.SpeedBoost = enabled
        
        if enabled then
            -- Aplica velocidade
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = SailorState.SpeedValue
            end
            
            -- Loop para manter velocidade
            Connections.Speed = RunService.Heartbeat:Connect(function()
                if SailorState.SpeedBoost then
                    local char = Player.Character
                    if char and char:FindFirstChild("Humanoid") then
                        if char.Humanoid.WalkSpeed ~= SailorState.SpeedValue then
                            char.Humanoid.WalkSpeed = SailorState.SpeedValue
                        end
                    end
                end
            end)
        else
            -- Remove velocidade
            if Connections.Speed then
                Connections.Speed:Disconnect()
                Connections.Speed = nil
            end
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = 16 -- Velocidade padrão
            end
        end
    end)
    
    CreateSlider(ContentContainer, "Speed Value", 16, 250, 50, function(value)
        SailorState.SpeedValue = value
        if SailorState.SpeedBoost then
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = value
            end
        end
    end, "")
    
    -- Informação
    local InfoFrame = Instance.new("Frame")
    InfoFrame.Parent = ContentContainer
    InfoFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    InfoFrame.BorderSizePixel = 0
    InfoFrame.Size = UDim2.new(1, 0, 0, 50)
    
    local InfoCorner = Instance.new("UICorner")
    InfoCorner.CornerRadius = UDim.new(0, 6)
    InfoCorner.Parent = InfoFrame
    
    local InfoText = Instance.new("TextLabel")
    InfoText.Parent = InfoFrame
    InfoText.BackgroundTransparency = 1
    InfoText.Size = UDim2.new(1, -20, 1, 0)
    InfoText.Position = UDim2.new(0, 10, 0, 0)
    InfoText.Font = Enum.Font.Gotham
    InfoText.Text = "⚡ Aumenta sua velocidade de movimento\nValores muito altos podem crashar"
    InfoText.TextColor3 = Color3.fromRGB(200, 200, 200)
    InfoText.TextSize = 12
    InfoText.TextWrapped = true
    InfoText.TextXAlignment = Enum.TextXAlignment.Left
end

