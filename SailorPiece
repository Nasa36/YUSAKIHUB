    label.TextScaled=true
    label.Font=Enum.Font.GothamBold
    label.TextXAlignment=Enum.TextXAlignment.Left
end

-- BUTTON FUNCTION
local function toggle(text,callback)
    local state=false
    local b=Instance.new("TextButton")
    b.Parent=scroll
    b.Size=UDim2.new(0.95,0,0,38)
    b.Text=text.." OFF"
    b.BackgroundColor3=Color3.fromRGB(35,35,50)
    b.TextColor3=Color3.new(1,1,1)
    b.TextScaled=true
    b.Font=Enum.Font.Gotham
    b.BorderSizePixel=0
    b.ZIndex=5
    local bCorner=Instance.new("UICorner",b)
bCorner.CornerRadius=UDim.new(0,10)
    local bStroke=Instance.new("UIStroke",b)
bStroke.Color=Color3.fromRGB(70,70,90)
bStroke.Thickness=1
    local function updateState()
        if state then
            b.Text=text.." ✓"
            b.BackgroundColor3=Color3.fromRGB(100,150,255)
bStroke.Color=Color3.fromRGB(150,200,255)
        else
            b.Text=text.." ✕"
            b.BackgroundColor3=Color3.fromRGB(35,35,50)
bStroke.Color=Color3.fromRGB(70,70,90)
        end
    end
    b.MouseButton1Click:Connect(function()
        state=not state
        updateState()
        callback(state)
    end)
    updateState()
end

